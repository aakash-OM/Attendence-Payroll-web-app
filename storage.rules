rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Documents are stored at documents/{companyId}/{empId}/{type}
    // Only the company owner (uid == companyId) can upload or delete
    match /documents/{companyId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == companyId;
    }
  }
}
